}

.ud-foldout > .unity-foldout__content .ud-toggle > .unity-toggle__label,
.ueh-foldout > .unity-foldout__content .ud-toggle > .unity-toggle__label,
.ueh-foldout > .unity-foldout__content .ueh-toggle > .unity-toggle__label {
    width: auto;
    min-width: 0px;
    flex-shrink: 1;
    padding-left: 2px;
    padding-right: 2px;
    font-size: 11px;
}

.ud-foldout > .unity-foldout__content .ud-toggle > .unity-toggle__input,
.ueh-foldout > .unity-foldout__content .ud-toggle > .unity-toggle__input,
.ueh-foldout > .unity-foldout__content .ueh-toggle > .unity-toggle__input {
    margin-left: 2px;
    margin-right: 4px;
}

.ud-scrollview--compact,
.ueh-scrollview--compact {
    max-height: 150px;
}

.ud-toolbar,
.ueh-toolbar {
